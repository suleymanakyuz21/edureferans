generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                          Int      @id @default(autoincrement())
  name                        String   @db.VarChar(100)
  email                       String   @unique @db.VarChar(255)
  password                    String
  role                        String   @default("USER") // USER | ADMIN
  isActive                    Boolean  @default(true)
  isVerified                  Boolean  @default(false)
  verificationCode            String?
  verificationCodeExpiresAt   DateTime?
  refCode                     String   @unique @db.VarChar(20)
  referredById                Int?
  grandReferredById           Int?
  balance                     Decimal  @default(0) @db.Decimal(12, 2)
  isPremium                   Boolean  @default(false)
  premiumSince                DateTime?
  phone                       String?  @db.VarChar(20)
  profession                  String?
  city                        String?
  about                       String?  @db.Text
  educationArea               String?
  experienceLevel             String?
  avatar                      String?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @default(now()) @updatedAt

  referredBy        User?          @relation("ReferredUsers", fields: [referredById], references: [id])
  referrals         User[]         @relation("ReferredUsers")
  grandReferredBy   User?          @relation("GrandReferredUsers", fields: [grandReferredById], references: [id])
  grandReferrals    User[]         @relation("GrandReferredUsers")

  payments          Payment[]
  payoutRequests    PayoutRequest[]
  commissionsGiven  Commission[]   @relation("CommissionFrom")
  commissionsEarned Commission[]   @relation("CommissionTo")
  sessions          Session[]
  notifications     Notification[]
  auditLogs         AuditLog[]

  @@index([email])
  @@index([refCode])
  @@index([referredById])
  @@index([grandReferredById])
}

model Payment {
  id           Int      @id @default(autoincrement())
  userId       Int
  amount       Decimal  @db.Decimal(12, 2)
  status       String   @default("COMPLETED")
  polarOrderId String?  @unique // Idempotency key from Polar webhook
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([polarOrderId])
}

model PayoutRequest {
  id          Int      @id @default(autoincrement())
  userId      Int
  amount      Decimal  @db.Decimal(12, 2)
  status      String   @default("PENDING") // PENDING | PROCESSING | COMPLETED | REJECTED
  method      String   // IBAN | PAPARA
  iban        String?
  paparaId    String?
  adminNote   String?
  processedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  user        User     @relation(fields: [userId], references: [id])

  @@index([userId, status])
}

model Commission {
  id         Int      @id @default(autoincrement())
  fromUserId Int
  toUserId   Int
  level      Int      // 1 or 2
  amount     Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now())

  fromUser   User     @relation("CommissionFrom", fields: [fromUserId], references: [id])
  toUser     User     @relation("CommissionTo", fields: [toUserId], references: [id])

  @@index([toUserId])
  @@index([fromUserId])
}

model Session {
  id        Int      @id @default(autoincrement())
  userId    Int
  device    String
  browser   String
  ip        String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Course {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @db.Text
  videoUrl    String
  provider    String   @default("Mux")
  thumbnail   String?
  category    String
  level       String?
  instructor  String?
  duration    String?
  isPremium   Boolean  @default(true)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String   // referral | commission | payment | admin | announcement
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
}

model Announcement {
  id        Int      @id @default(autoincrement())
  title     String
  message   String   @db.Text
  type      String   // INFO | PROMO | UPDATE | MAINTENANCE
  createdAt DateTime @default(now())
}

model SupportTicket {
  id        Int      @id @default(autoincrement())
  userId    Int?
  name      String
  email     String
  message   String   @db.Text
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  adminId   Int
  action    String
  targetId  String?
  details   String?  @db.Text
  createdAt DateTime @default(now())

  admin     User     @relation(fields: [adminId], references: [id])

  @@index([adminId])
}
