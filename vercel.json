{
  "version": 2,
  "public": false,
  "buildCommand": "cd frontend && npm install && npm run build",
  "installCommand": "cd frontend && npm install",
  "framework": "nextjs",
  "regions": ["cdg1"],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://edureferans-backend.vercel.app/api/:path*"
    }
  ]
}
