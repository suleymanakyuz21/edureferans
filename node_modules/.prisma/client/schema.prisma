// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int      @id @default(autoincrement())
  name              String
  email             String   @unique
  password          String
  refCode           String   @unique
  referredById      Int?
  grandReferredById Int?
  balance           Float    @default(0)
  isPremium         Boolean  @default(false)
  isVerified        Boolean  @default(false)
  verificationCode  String?
  phone             String?
  profession        String?
  city              String?
  about             String?  @db.Text
  educationArea     String?
  experienceLevel   String?
  avatar            String?
  createdAt         DateTime @default(now())

  // Relations
  referredBy User?  @relation("ReferredUsers", fields: [referredById], references: [id])
  referrals  User[] @relation("ReferredUsers")

  grandReferredBy User?  @relation("GrandReferredUsers", fields: [grandReferredById], references: [id])
  grandReferrals  User[] @relation("GrandReferredUsers")

  payments          Payment[]
  commissionsGiven  Commission[]   @relation("CommissionFrom")
  commissionsEarned Commission[]   @relation("CommissionTo")
  sessions          Session[]
  notifications     Notification[]
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String // referral, commission, payment, admin
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Session {
  id        Int      @id @default(autoincrement())
  userId    Int
  device    String
  browser   String
  ip        String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Course {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  videoUrl    String
  category    String
  createdAt   DateTime @default(now())
}

model Payment {
  id        Int      @id @default(autoincrement())
  userId    Int
  amount    Float
  status    String   @default("COMPLETED")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Commission {
  id         Int      @id @default(autoincrement())
  fromUserId Int
  toUserId   Int
  level      Int // 1 or 2
  amount     Float
  createdAt  DateTime @default(now())

  fromUser User @relation("CommissionFrom", fields: [fromUserId], references: [id])
  toUser   User @relation("CommissionTo", fields: [toUserId], references: [id])
}

model SupportTicket {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String   @db.Text
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
}
